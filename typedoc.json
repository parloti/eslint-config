{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts", "src/configs/index.ts"],
  "entryPointStrategy": "resolve",
  "excludeInternal": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "githubPages": false,
  "hideGenerator": true,
  "intentionallyNotExported": ["PluginName"],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none"
}
